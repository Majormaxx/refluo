# Real Stellar RPC and network passphrase. Testnet defaults shown.
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# The one vault this dashboard instance operates (PRD 8.2's own auth
# model is single-vault: admin/guardian membership is checked against
# this specific deployment, not a multi-tenant registry).
VAULT_ADDRESS=
RISK_ENGINE_ID=
# The plain identity RiskEngine's own `account` parameter tracks state
# under (RiskEngine.init() requires this address's own auth directly, it
# cannot be the vault contract itself without routing through the SDK's
# signing module just to read state). Matches keeper/.env.example's own
# ACCOUNT convention; use the same value here.
RISK_ENGINE_ACCOUNT=
HEALTH_MONITOR_ID=
TIMELOCK_ID=
USDC_TOKEN_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
XLM_TOKEN_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Same values, NEXT_PUBLIC_-prefixed so Next.js inlines them into the
# browser bundle for client-side signing actions (lib/actions/*.ts):
# contract ids and network params are public addresses, not secrets.
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_HEALTH_MONITOR_ID=
NEXT_PUBLIC_TIMELOCK_ID=

# Real secret used to HMAC-sign session cookies (lib/auth/session.ts).
# Generate one with: openssl rand -hex 32
SESSION_SECRET=

# Where keeper/src/reporterLoop.ts (adr/0019) writes its real SlaSnapshot.
# Point this at the same file/shared volume the keeper process writes to;
# a relative default assumes dashboard/ and keeper/ share a parent dir.
REPORTER_SNAPSHOT_FILE=../keeper/.reporter-snapshot.json

# Local JSON file storing this admin's alert-routing config
# (lib/alertsConfig.ts). Single-operator, single-vault scope (PRD 8.2),
# not a database.
ALERTS_CONFIG_FILE=.alerts-config.json

# How far back (in ledgers, not days: adr/0021's own finding is that the
# public testnet RPC's real getEvents retention fluctuates and is bounded
# in ledgers, not a stable calendar window) to replay real propose/
# execute/cancel events when reconstructing the pending timelock queue
# (lib/contracts/timelockProposals.ts). 10,000 is the value confirmed
# live to hold safely; a genuinely pending proposal older than this still
# exists on-chain and is directly readable via get_proposal(id), it just
# will not appear in this reconstructed queue. Raise this if your RPC
# provider retains events further back.
TIMELOCK_PROPOSALS_LOOKBACK_LEDGERS=10000

# How far back to look for the real Paused event that set the current
# pause_expiry (lib/contracts/healthMonitor.ts). Same real RPC retention
# caveat as above; a pause up to the contract's own 72h
# MAX_PAUSE_DURATION old may not be found on every RPC provider, in which
# case pauseExpirySeconds comes back null (status() itself is unaffected).
HEALTH_MONITOR_PAUSE_LOOKBACK_LEDGERS=10000
