# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files, except the real .env.example documenting what's needed
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# real local state: this operator's own alerts config (lib/alertsConfig.ts)
# and the keeper's SLA snapshot mirror, never committed (adr/0021)
.alerts-config.json
.smoke-alerts-config.json
.reporter-snapshot.json
.smoke-reporter-snapshot.json
