# Stellar network RPC and passphrase. Testnet defaults shown.
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Keeper's own signing key (secret seed, S...). Never commit a real one;
# this file is an example, the real .env is gitignored.
KEEPER_SECRET=

# The account (vault admin address) RiskEngine tracks state for, and the
# deployed RiskEngine contract id.
RISK_ENGINE_ID=
ACCOUNT=

# The real Blend V2 pool to read reserve utilization from, and which
# reserve (asset) in that pool to monitor. Testnet defaults point at the
# live pool this workspace verified in adr/0012.
BLEND_POOL_ID=CCEBVDYM32YNYCVNRXQKDFFPISJJCV557CDZEIRBEE4NCV4KHPQ44HGF
RESERVE_ASSET_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Poll interval in seconds. PRD's own architecture names 1min for the
# sentinel loop this utilization monitor is part of.
POLL_INTERVAL_SECONDS=60
