# Stellar network RPC and passphrase. Testnet defaults shown.
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Keeper's own signing key (secret seed, S...). Never commit a real one;
# this file is an example, the real .env is gitignored.
KEEPER_SECRET=

# The account (vault admin address) RiskEngine tracks state for, and the
# deployed RiskEngine contract id.
RISK_ENGINE_ID=
ACCOUNT=

# The real Blend V2 pool to read reserve utilization from, and which
# reserve (asset) in that pool to monitor. Testnet defaults point at the
# live pool this workspace verified in adr/0012.
BLEND_POOL_ID=CCEBVDYM32YNYCVNRXQKDFFPISJJCV557CDZEIRBEE4NCV4KHPQ44HGF
RESERVE_ASSET_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Poll interval in seconds. PRD's own architecture names 1min for the
# sentinel loop this utilization monitor is part of.
POLL_INTERVAL_SECONDS=60

# swap.ts (XLM fee-floor auto-swap, adr/0015 + adr/0016): submits through
# the real vault contract, not this keeper's own balance. VAULT_ADDRESS
# must have a context rule (SWAP_CONTEXT_RULE_ID) naming this keeper's
# KEEPER_SECRET address as a delegated signer with policy-swap attached,
# a session scope distinct from R_ADMIN (see adr/0016 for how to install
# one). Real Soroswap router and real USDC/XLM SAC token ids below;
# testnet defaults point at the live infrastructure this workspace
# verified (adr/0012-adjacent verification, adr/0015).
VAULT_ADDRESS=
SWAP_CONTEXT_RULE_ID=
XLM_TOKEN_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
USDC_TOKEN_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
SOROSWAP_ROUTER_ID=CCJUD55AG6W5HAI5LRVNKAE5WDP5XGZBUDS5WNTIVDU7O264UZZE7BRD
# A deployed oracle-router configured for XLM (see
# contracts/oracle-router/scripts/testnet_smoke_test.sh to stand one up).
ORACLE_ROUTER_ID=
ORACLE_ASSET_SYMBOL=XLM

# Floor and top-up target, in XLM stroops (7 decimals). Balance below the
# floor triggers a swap sized to reach the target, never below it.
XLM_FLOOR_STROOPS=1000000000
XLM_TOPUP_TARGET_STROOPS=5000000000
# bps of oracle-fair value the real router's amount_out_min must clear,
# matching policy-swap's own on-chain enforcement (adr/0015).
SWAP_MIN_OUT_BPS=9700
SWAP_DEADLINE_SECONDS=60
SWAP_POLL_INTERVAL_SECONDS=300

# forecasterLoop.ts (Tier 0 sizing, adr/0017): reads real USDC transfer
# events out of VAULT_ADDRESS and writes a real risk-engine.set_tier0_target
# when the computed target diverges from the on-chain value. RECALL_WINDOW_SECONDS
# should match policy-recall's own RecallConfig.window for the same vault.
RECALL_WINDOW_SECONDS=3600
# Operator-set buffer multiplier over the raw P99 burn-rate estimate; not
# a fixed on-chain-style preset (Tier 0 sizing runs off-chain, RiskEngine's
# own tier0_bounds_min/max remain the real safety net regardless of k).
FORECASTER_K=1.5
# USDC-equivalent buffer so a real XLM fee-floor top-up (adr/0015) never
# dips Tier 0 below its own minimum.
XLM_FEE_FLOOR_USD_STROOPS=1000000
# Only write on-chain when the proposed target diverges from the current
# value by more than this many bps.
FORECASTER_BAND_BPS=500
# Trigger a real recall once tier0 balance falls below this bps of the
# applied target.
FORECASTER_REFILL_BAND_BPS=2000
# How far back to replay real burn history; the RPC's own real event
# retention window (~7 days on public testnet) is the practical ceiling.
FORECASTER_LOOKBACK_HOURS=168
FORECASTER_STATE_FILE=.forecaster-state.json
FORECASTER_POLL_INTERVAL_SECONDS=300
# Only needed if a real recall should fire when tier0 runs low: which
# context rule R_RECALL is on VAULT_ADDRESS, and the real Blend venue to
# recall from. Leave unset to size Tier 0 without ever triggering a recall.
RECALL_CONTEXT_RULE_ID=
RECALL_VENUE_ID=
